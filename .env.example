# PromptlyOS Environment Variables
# Copy this to .env.local and fill values for local development (DO NOT commit .env.local)

# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# OpenAI Configuration
VITE_OPENAI_API_KEY=your_openai_api_key_here

# Market Research APIs (Optional)
VITE_LINKEDIN_API_KEY=your_linkedin_api_key
VITE_INDEED_API_KEY=your_indeed_api_key

# Application Configuration
VITE_APP_NAME=PromptlyOS
VITE_APP_VERSION=1.0.0
VITE_APP_DESCRIPTION=Premium multi-role career & work operating system

# Feature Flags
VITE_ENABLE_AI_FEATURES=true
VITE_ENABLE_MARKET_RESEARCH=true
VITE_ENABLE_REAL_TIME_UPDATES=true

# Development Settings
VITE_DEV_MODE=true
VITE_DEBUG_AI=false

# Use a local .env (NOT committed) or set these in your CI/environment
